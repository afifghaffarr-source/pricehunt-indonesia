{
  "manifest_version": 3,
  "name": "PriceHunt Indonesia",
  "version": "1.0.0",
  "description": "Bandingkan harga marketplace Indonesia saat browsing",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://pricehunt-indonesia.vercel.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PriceHunt"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tokopedia.com/*",
        "*://*.shopee.co.id/*",
        "*://*.bukalapak.com/*",
        "*://*.lazada.co.id/*",
        "*://*.blibli.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
