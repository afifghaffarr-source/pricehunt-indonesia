{
  "manifest_version": 3,
  "name": "BijakBeli.app",
  "short_name": "BijakBeli",
  "version": "3.0.1",
  "description": "Bandingkan harga marketplace Indonesia saat browsing. Auto-scrape produk untuk bantu komunitas.",
  "author": "BijakBeli Team",
  "homepage_url": "https://www.bijakbeli.web.id/extension",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.bijakbeli.web.id/*",
    "https://shopee.co.id/*",
    "https://*.shopee.co.id/*",
    "https://www.tokopedia.com/*",
    "https://www.lazada.co.id/*",
    "https://www.blibli.com/*",
    "https://www.bukalapak.com/*",
    "https://shop.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BijakBeli"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.tokopedia.com/*",
        "*://*.shopee.co.id/*",
        "*://*.bukalapak.com/*",
        "*://*.lazada.co.id/*",
        "*://*.blibli.com/*",
        "*://shop.tiktok.com/*"
      ],
      "js": ["marketplace-scraper.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
