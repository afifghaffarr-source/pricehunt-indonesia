# ===========================================
# PriceHunt Indonesia - Vercel Production Env
# ===========================================
# Copy file ini menjadi .env.production.local, lalu isi value asli.
# Jangan commit .env.production.local. File tersebut berisi secret production.

# Supabase public client env. NEXT_PUBLIC_* akan tersedia di browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role hanya untuk server-side job/admin/cron.
# Jangan pernah expose value ini ke browser atau NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App URL production. Gunakan domain Vercel/custom domain final.
NEXT_PUBLIC_APP_URL=https://your-production-domain.vercel.app

# Cron protection. Pakai random string panjang.
CRON_SECRET=replace-with-long-random-secret

# Price simulation untuk development/testing.
# WAJIB false di production! Jika true, cron akan generate harga random untuk testing.
# Jika false, cron tidak akan mengubah harga secara random.
ENABLE_PRICE_SIMULATION=false

# Ingestion API protection. Hanya digunakan oleh Python collector dan system internal.
# Generate random string panjang. Jangan expose ke browser.
INGESTION_SECRET=replace-with-long-random-secret

# AI providers. Isi hanya jika fitur AI/Vexo aktif di production.
OPENAI_API_KEY=sk-your-openai-api-key
VEXO_API_BASE_URL=https://vexoapi.azzamcodex.site
VEXO_API_KEY=your-vexo-api-key
VEXO_API_TIMEOUT_MS=10000
VEXO_CACHE_TTL_SECONDS=3600

# Email provider untuk alert dan digest.
RESEND_API_KEY=re_your-resend-api-key

# Web Push. Generate VAPID key pair sebelum production.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Optional Vercel automation token, hanya jika ingin deploy/env push via CLI non-interaktif.
# VERCEL_TOKEN=your-vercel-token