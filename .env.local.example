# ===========================================
# PriceHunt Indonesia — Environment Variables
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI (untuk AI Advisor)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Resend (untuk email notifikasi price alert)
RESEND_API_KEY=re_your-resend-api-key-here

# App URL (untuk OG images dan email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Cron & System Protection
# ===========================================
# Cron secret untuk protect cron endpoints
# Untuk development, pakai secret simple. Production harus random panjang.
CRON_SECRET=dev-cron-secret-change-in-production

# Price simulation untuk development/testing
# true = cron akan generate harga random untuk testing
# false = cron tidak akan mengubah harga (tunggu data real dari ingestion)
ENABLE_PRICE_SIMULATION=true

# Ingestion API protection (akan digunakan Python collector)
# Untuk development, pakai secret simple. Production harus random panjang.
INGESTION_SECRET=dev-ingestion-secret-change-in-production

# ===========================================
# VexoAPI (Product Discovery + AI Search)
# ===========================================
# Dapatkan VIP Key dari VexoAPI
VEXO_API_BASE_URL=https://vexoapi.azzamcodex.site
VEXO_API_KEY=your_vexo_api_key_here
VEXO_API_TIMEOUT_MS=10000
VEXO_CACHE_TTL_SECONDS=3600

# ===========================================
# Web Push Notifications (Optional)
# ===========================================
# Generate VAPID key pair: npx web-push generate-vapid-keys
# Untuk development bisa skip dulu jika tidak test push notification
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:dev@localhost
