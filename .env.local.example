# ===========================================
# BijakBeli.app — Environment Variables
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI (untuk AI Advisor)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Resend (untuk email notifikasi price alert)
RESEND_API_KEY=re_your-resend-api-key-here

# App URL (untuk OG images dan email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Cron & System Protection
# ===========================================
# Cron secret untuk protect cron endpoints.
# Vercel Cron mengirim header `Authorization: Bearer <CRON_SECRET>` secara otomatis.
# Untuk development, pakai secret simple. Production harus random panjang (>= 32 char).
#
# Development: placeholder di bawah aman untuk local saja. Server menolak
# semua request production dengan placeholder ini (override via Vercel env).
#
# Production WAJIB: secret random >= 32 char, di-rotate tiap tahun atau
# saat suspected leak. Generate:
#   PowerShell: -join ((1..48) | ForEach-Object { [char[]]'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789' | Get-Random })
#   Bash:       openssl rand -base64 48 | tr -d '=+/' | cut -c1-48
# Lihat: docs/SECRET_ROTATION.md untuk prosedur lengkap.
#
# JANGAN copy nilai di bawah ini ke Vercel/GitHub secrets.
CRON_SECRET=__REPLACE_WITH_RANDOM_48_CHAR_SECRET_IN_PRODUCTION__

# Price simulation untuk development/testing.
# true  = /api/cron/prices akan generate harga random untuk testing
# false = /api/cron/prices tidak akan mengubah harga (tunggu data real dari ingestion)
# WAJIB: false di production agar tidak menimpa harga real dari ingestion API.
ENABLE_PRICE_SIMULATION=true

# ===========================================
# Cron Schedules (configured in vercel.json)
# ===========================================
# /api/cron/alerts   -> setiap jam   ("0 * * * *")
#   Memproses price_alerts yang triggered (current_price <= target_price), kirim email via Resend.
# /api/cron/prices   -> setiap 6 jam ("0 */6 * * *")
#   Hanya jalan jika ENABLE_PRICE_SIMULATION=true. Di production, harga real
#   datang dari ingestion API (POST /api/ingestion/offer-snapshot), bukan cron ini.
# /api/cron/digest   -> tiap Senin 09:00 UTC ("0 9 * * 1")
#   Kirim weekly email digest ke user yang opt-in (preferences.email_digest_enabled=true).
#
# Semua endpoint cron memanggil verifyCronSecret(request) di awal handler.
# Tanpa secret valid, request ditolak 401.
#
# Vercel Cron limits (cek plan Anda):
#   Hobby: 2 crons/day   -> alert (24/day) TIDAK muat, naik ke Pro
#   Pro:   40 crons/day  -> aman untuk ketiga jadwal di atas

# Ingestion API protection (akan digunakan Python collector)
# Melindungi endpoint POST /api/ingestion/offer-snapshot dari public write.
# Header yang dikirim collector: "X-Ingestion-Secret: <value>".
#
# Development: placeholder di bawah aman untuk local saja. Server menolak
# semua request production dengan placeholder ini.
#
# Production WAJIB: secret random >= 32 char, disimpan di:
#   - Vercel env (production scope) untuk /api/ingestion
#   - collectors/.env (NOT committed) untuk Python scraper
# Lihat: docs/SECRET_ROTATION.md.
#
# JANGAN copy nilai di bawah ini ke Vercel environment variables.
INGESTION_SECRET=__REPLACE_WITH_RANDOM_48_CHAR_SECRET_IN_PRODUCTION__

# ===========================================
# VexoAPI (Product Discovery + AI Search)
# ===========================================
# Dapatkan VIP Key dari VexoAPI dashboard.
# Production WAJIB: real key. JANGAN commit real key ke git.
VEXO_API_BASE_URL=https://vexoapi.dev
VEXO_API_KEY=__REPLACE_WITH_REAL_VEXO_VIP_KEY__
VEXO_API_TIMEOUT_MS=10000
VEXO_CACHE_TTL_SECONDS=3600

# ===========================================
# Web Push Notifications (Optional)
# ===========================================
# Push notifications digunakan untuk price alert instan.
# User dapat enable push notifications di settings atau product detail page.
#
# Generate VAPID key pair dengan command:
#   npx web-push generate-vapid-keys
#
# Untuk development bisa skip dulu jika tidak test push notification.
# Push notification akan fallback ke email jika VAPID keys tidak diset.
#
# Production WAJIB: real keys. VAPID_PRIVATE_KEY hanya boleh di Vercel env,
# BUKAN di repo manapun.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=__REPLACE_WITH_GENERATED_VAPID_PUBLIC_KEY__
VAPID_PRIVATE_KEY=__REPLACE_WITH_GENERATED_VAPID_PRIVATE_KEY__
VAPID_SUBJECT=mailto:dev@localhost

# ===========================================
# Sentry Error Tracking (Optional, free tier 5K errors/mo)
# ===========================================
# Setup: https://sentry.io → Create Next.js project → Copy DSN
# Without DSN, Sentry is a no-op (code still safe to ship).
# Set in Vercel env vars for production: NEXT_PUBLIC_SENTRY_DSN, SENTRY_AUTH_TOKEN (optional, for source maps)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
