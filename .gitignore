venv/
.venv/
env/
.env/
collectors/venv/

# Backup and temp files
*.backup
*.backup-*
*.temp
*.tmp
*.old
*~

# Cache directories
.codegraph/cache/

# Local test outputs
test.out

build.out


# Playwright
test-results/
playwright-report/
playwright/.cache/

# Lighthouse CI
lighthouse-reports/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
