{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/alerts/check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/prices",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 8 * * 0"
    }
  ]
}
