{
  "manifest_version": 3,
  "version": "2.0.2",
  "name": "BijakBeli Product Collector",
  "description": "Collect product data from Indonesian marketplaces (Tokopedia, Shopee, Bukalapak) to BijakBeli.app with one click!",
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://www.tokopedia.com/*",
    "https://tokopedia.com/*",
    "https://shopee.co.id/*",
    "https://www.bukalapak.com/*",
    "https://www.bijakbeli.app/*",
    "https://bijakbeli.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tokopedia.com/*/*",
        "https://tokopedia.com/*/*",
        "https://shopee.co.id/*-i.*",
        "https://www.bukalapak.com/p/*/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
